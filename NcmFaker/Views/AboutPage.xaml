<Page
    x:Class="NcmFaker.Views.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NcmFaker.Views">

    <Grid Padding="30">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="30" MaxWidth="800" HorizontalAlignment="Left">

                <TextBlock Text="关于" FontSize="28" FontWeight="Bold" Margin="0,0,0,10"/>

                <StackPanel Orientation="Horizontal" Spacing="20" VerticalAlignment="Center">
                    <Border Width="80" Height="80" CornerRadius="16" Background="{ThemeResource SystemAccentColor}" VerticalAlignment="Top">
                        <FontIcon Glyph="&#xE8B7;" FontSize="40" Foreground="White"/>
                    </Border>

                    <StackPanel Spacing="5" VerticalAlignment="Center">
                        <TextBlock Text="NcmFaker" FontSize="24" FontWeight="Bold"/>
                        <TextBlock Text="版本: v1.0.0 Beta" Foreground="Gray" FontSize="14"/>
                        <TextBlock Text="一款现代、极速、优雅的本地音频处理工具。" FontSize="14" Margin="0,5,0,0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Spacing="10">
                    <TextBlock Text="开发者" FontWeight="SemiBold" FontSize="16"/>
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1" CornerRadius="8" Padding="20">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE77B;" FontSize="16" Foreground="Gray"/>
                                <TextBlock Text="Casper-003" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE715;" FontSize="16" Foreground="Gray"/>
                                <HyperlinkButton Content="casper-003@outlook.com" 
                                                 Click="EmailButton_Click" 
                                                 Padding="0" MinHeight="0" BorderThickness="0"/>
                            </StackPanel>
                            <TextBlock Text="如果你在使用过程中遇到任何 Bug，或者有新功能的建议，欢迎随时通过邮件与我联系交流！" 
                                       Foreground="Gray" FontSize="12" TextWrapping="Wrap" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Spacing="10">
                    <TextBlock Text="开源组件致谢" FontWeight="SemiBold" FontSize="16"/>
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1" CornerRadius="8" Padding="20">
                        <StackPanel Spacing="10">
                            <TextBlock Text="本软件的诞生离不开以下优秀开源项目的支持：" Foreground="Gray" FontSize="12" Margin="0,0,0,5"/>

                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="•" FontSize="14" VerticalAlignment="Center"/>
                                <HyperlinkButton Content="libncmdump" NavigateUri="https://github.com/taurusxin/ncmdump" Padding="0" MinHeight="0" BorderThickness="0" VerticalAlignment="Center" FontSize="14"/>
                                <TextBlock Text="- 强大的 NCM 文件解密核心" FontSize="14" Foreground="Gray" VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="•" FontSize="14" VerticalAlignment="Center"/>
                                <HyperlinkButton Content="TagLib-sharp" NavigateUri="https://github.com/mono/taglib-sharp" Padding="0" MinHeight="0" BorderThickness="0" VerticalAlignment="Center" FontSize="14"/>
                                <TextBlock Text="- 全面的音频元数据与 ID3 标签读写库" FontSize="14" Foreground="Gray" VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="•" FontSize="14" VerticalAlignment="Center"/>
                                <HyperlinkButton Content="WinUI 3 &amp; Windows App SDK" NavigateUri="https://github.com/microsoft/microsoft-ui-xaml" Padding="0" MinHeight="0" BorderThickness="0" VerticalAlignment="Center" FontSize="14"/>
                                <TextBlock Text="- 提供现代化的流畅 UI 框架" FontSize="14" Foreground="Gray" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Spacing="10">
                    <TextBlock Text="法律与免责声明" FontWeight="SemiBold" FontSize="16"/>
                    <Border Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}" 
                            BorderBrush="{ThemeResource SystemFillColorCriticalBrush}" 
                            BorderThickness="1" CornerRadius="8" Padding="20">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE7BA;" FontSize="16" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                <TextBlock Text="请务必阅读" FontWeight="Bold" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                            </StackPanel>
                            <TextBlock Text="本软件仅供个人学习、编程技术交流以及本地音频文件整理使用。请勿将本软件用于任何形式的商业盈利用途，或在未经授权的情况下大量传播受版权保护的数字作品。请在解密测试后的 24 小时内删除相关音频文件。" 
                                       TextWrapping="Wrap" FontSize="13" LineHeight="20"/>
                            <TextBlock Text="请支持正版音乐。因使用本软件引发的一切版权纠纷或法律责任，由使用者自行承担，开发者概不负责。" 
                                       TextWrapping="Wrap" FontSize="13" FontWeight="SemiBold" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>