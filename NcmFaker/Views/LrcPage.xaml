<Page
    x:Class="NcmFaker.Views.LrcPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NcmFaker.Views">

    <Grid x:Name="RootGrid" Padding="30" AllowDrop="True" DragOver="Grid_DragOver" Drop="Grid_Drop">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <Grid VerticalAlignment="Top" Margin="0,10,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15*" MaxWidth="900"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="1" Spacing="25">
                    <FontIcon Glyph="&#xE8B7;" FontSize="72" Foreground="{ThemeResource SystemAccentColor}" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="SetSourceBtn" Click="SetSourceBtn_Click" Grid.Column="0" HorizontalAlignment="Stretch" Style="{StaticResource AccentButtonStyle}" MinHeight="45">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE838;" FontSize="16"/>
                                <TextBlock Text="扫描音频文件夹" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="OpenFolderBtn" Grid.Column="1" Click="OpenFolderBtn_Click" HorizontalAlignment="Stretch" MinHeight="45" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8D5;" FontSize="16" Foreground="{ThemeResource SystemAccentColor}"/>
                                <TextBlock Text="在资源管理器中打开" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Expander x:Name="AdvancedOptionsExpander" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal" Spacing="10" Padding="5,0">
                                <FontIcon Glyph="&#xE713;" FontSize="16"/>
                                <TextBlock Text="高级匹配与修复选项" FontWeight="Bold" FontSize="15"/>
                            </StackPanel>
                        </Expander.Header>
                        <Expander.Content>
                            <Grid Padding="15,20,15,15" ColumnSpacing="30">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Spacing="12">
                                    <TextBlock Text="🔍 匹配引擎" Foreground="Gray" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <CheckBox x:Name="RegexCleanCheck" Content="智能清洗文件名/标签 (过滤无用后缀)" IsChecked="True"/>
                                    <CheckBox x:Name="MergeTransCheck" Content="合并中文翻译 (若平台提供)" IsChecked="True"/>
                                    <CheckBox x:Name="MergeRomaCheck" Content="合并罗马音 (若平台提供)" IsChecked="False"/>
                                </StackPanel>

                                <Border Grid.Column="1" Width="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,5"/>

                                <StackPanel Grid.Column="2" Spacing="12">
                                    <TextBlock Text="💾 数据写入" Foreground="Gray" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <CheckBox x:Name="SaveLrcFileCheck" Content="在同级目录保存 .lrc 外挂歌词" IsChecked="True"/>
                                    <CheckBox x:Name="EmbedLrcCheck" Content="将歌词直接打入音频文件内部 (ID3)" IsChecked="True"/>
                                    <CheckBox x:Name="EmbedCoverCheck" Content="获取高清封面并内嵌至音频" IsChecked="True"/>
                                </StackPanel>
                            </Grid>
                        </Expander.Content>
                    </Expander>

                    <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Height="350">
                        <ListView x:Name="TaskListView" SelectionMode="None">
                            <ListView.Header>
                                <Grid Margin="0,0,0,10" Padding="10,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="4*" />
                                        <ColumnDefinition Width="3*" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="文件名" FontWeight="Bold" Foreground="Gray"/>
                                    <TextBlock Grid.Column="1" Text="匹配进度" FontWeight="Bold" Foreground="Gray"/>
                                    <TextBlock Grid.Column="2" Text="状态" FontWeight="Bold" Foreground="Gray"/>
                                    <TextBlock Grid.Column="3" Text="操作" FontWeight="Bold" Foreground="Gray" HorizontalAlignment="Center"/>
                                </Grid>
                            </ListView.Header>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:LrcTaskItem">
                                    <Grid Padding="0,8" ColumnSpacing="15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4*" />
                                            <ColumnDefinition Width="3*" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="60" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{x:Bind FileName}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{x:Bind FileName}"/>

                                        <ProgressBar Grid.Column="1" Value="{x:Bind Progress, Mode=OneWay}" Maximum="100" VerticalAlignment="Center" Foreground="{ThemeResource SystemAccentColor}" />

                                        <TextBlock Grid.Column="2" Text="{x:Bind Status, Mode=OneWay}" VerticalAlignment="Center" Foreground="Gray" FontSize="12"/>

                                        <Button Grid.Column="3" Content="取消" Click="CancelTask_Click" Tag="{x:Bind}" Background="Transparent" BorderThickness="0" Foreground="Red" IsEnabled="{x:Bind IsActionable, Mode=OneWay}" HorizontalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <Grid Grid.Row="1" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15*" MaxWidth="900"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="1" Height="55" CornerRadius="8" BorderBrush="{ThemeResource SystemAccentColor}" BorderThickness="1">
                <ProgressBar x:Name="MatchProgressBar" Minimum="0" Maximum="100" Value="0" VerticalAlignment="Bottom" Height="4" Background="Transparent" CornerRadius="0,0,8,8"/>
                <Button x:Name="StartMatchBtn" Click="StartMatchBtn_Click" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent" BorderThickness="0" Padding="10">
                    <TextBlock Text="开始智能匹配" FontSize="18" FontWeight="Bold" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center"/>
                </Button>
            </Grid>
        </Grid>

    </Grid>
</Page>