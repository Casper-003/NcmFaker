<Page
    x:Class="NcmFaker.Views.FileConvertPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NcmFaker.Views">

    <Grid x:Name="RootGrid" Padding="30" AllowDrop="True" DragOver="Grid_DragOver" Drop="Grid_Drop">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <Grid VerticalAlignment="Top" Margin="0,10,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15*" MaxWidth="900"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="1" Spacing="25">
                    <FontIcon Glyph="&#xE8B7;" FontSize="72" Foreground="{ThemeResource SystemAccentColor}" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <DropDownButton Grid.Column="0" HorizontalAlignment="Stretch" Style="{StaticResource AccentButtonStyle}" MinHeight="45">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE710;" FontSize="16"/>
                                <TextBlock Text="添加 NCM 数据源" FontWeight="SemiBold"/>
                            </StackPanel>
                            <DropDownButton.Flyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="选择文件..." Click="AddFilesItem_Click">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE8E5;"/>
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem Text="导入整个文件夹..." Click="AddFolderItem_Click">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE838;"/>
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyout>
                            </DropDownButton.Flyout>
                        </DropDownButton>

                        <Button x:Name="OpenFolderBtn" Grid.Column="1" Click="OpenFolderBtn_Click" HorizontalAlignment="Stretch" MinHeight="45" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8D5;" FontSize="16" Foreground="{ThemeResource SystemAccentColor}"/>
                                <TextBlock Text="打开输出文件夹 (transferred)" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Height="350">
                        <ListView x:Name="TaskListView" SelectionMode="None">
                            <ListView.Header>
                                <Grid Margin="0,0,0,10" Padding="10,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="4*" />
                                        <ColumnDefinition Width="3*" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="文件名" FontWeight="Bold" Foreground="Gray"/>
                                    <TextBlock Grid.Column="1" Text="进度" FontWeight="Bold" Foreground="Gray"/>
                                    <TextBlock Grid.Column="2" Text="状态" FontWeight="Bold" Foreground="Gray"/>
                                    <TextBlock Grid.Column="3" Text="操作" FontWeight="Bold" Foreground="Gray" HorizontalAlignment="Center"/>
                                </Grid>
                            </ListView.Header>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:ConvertTaskItem">
                                    <Grid Padding="0,8" ColumnSpacing="15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4*" />
                                            <ColumnDefinition Width="3*" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="60" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{x:Bind FileName}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{x:Bind FileName}"/>

                                        <ProgressBar Grid.Column="1" Value="{x:Bind Progress, Mode=OneWay}" Maximum="100" VerticalAlignment="Center" Foreground="{ThemeResource SystemAccentColor}" />

                                        <TextBlock Grid.Column="2" Text="{x:Bind Status, Mode=OneWay}" VerticalAlignment="Center" Foreground="Gray" FontSize="12"/>

                                        <Button Grid.Column="3" Content="取消" Click="CancelTask_Click" Tag="{x:Bind}" Background="Transparent" BorderThickness="0" Foreground="Red" IsEnabled="{x:Bind IsActionable, Mode=OneWay}" HorizontalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <Grid Grid.Row="1" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15*" MaxWidth="900"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="1" Height="55" CornerRadius="8" BorderBrush="{ThemeResource SystemAccentColor}" BorderThickness="1">
                <ProgressBar x:Name="ConvertProgressBar" Minimum="0" Maximum="100" Value="0" VerticalAlignment="Bottom" Height="4" Background="Transparent" CornerRadius="0,0,8,8"/>
                <Button x:Name="StartConvertBtn" Click="StartConvertBtn_Click" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent" BorderThickness="0" Padding="10">
                    <TextBlock Text="开始极速转换" FontSize="18" FontWeight="Bold" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center"/>
                </Button>
            </Grid>
        </Grid>

    </Grid>
</Page>