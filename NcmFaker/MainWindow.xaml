<Window
    x:Class="NcmFaker.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NcmFaker">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Grid.Row="0" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <FontIcon Glyph="&#xE189;" FontSize="16" Margin="15,0,10,0" Grid.Column="0" Foreground="{ThemeResource SystemAccentColor}"/>
            <TextBlock Text="NcmFaker" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Grid.Column="1"/>

            <Button x:Name="RefreshBtn" Click="RefreshBtn_Click" Grid.Column="2" Background="Transparent" BorderThickness="0" Margin="10,0,0,0" VerticalAlignment="Center" ToolTipService.ToolTip="清空列表">
                <FontIcon Glyph="&#xE149;" FontSize="14"/>
            </Button>

            <Button x:Name="NotificationBtn" Grid.Column="3" Background="Transparent" BorderThickness="0" Margin="5,0,0,0" VerticalAlignment="Center" ToolTipService.ToolTip="通知中心">
                <Grid>
                    <FontIcon Glyph="&#xEA8F;" FontSize="14"/>
                    <Ellipse x:Name="UnreadBadge" Width="8" Height="8" Fill="Red" 
                             HorizontalAlignment="Right" VerticalAlignment="Top" 
                             Margin="0,-2,-2,0" Visibility="Collapsed"/>
                </Grid>

                <Button.Flyout>
                    <Flyout x:Name="NotifFlyout" Opened="NotifFlyout_Opened">
                        <Grid Width="320" Height="400">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="通知记录" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                            <Button Content="清空" Click="ClearLogs_Click" Background="Transparent" BorderThickness="0" HorizontalAlignment="Right" Foreground="Gray"/>

                            <ListView x:Name="LogListView" Grid.Row="1" Margin="0,10,0,0" SelectionMode="None" ItemsSource="{x:Bind SystemLogs}">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="local:LogItem">
                                        <StackPanel Margin="0,0,0,12">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{x:Bind Time}" FontSize="12" Foreground="Gray" VerticalAlignment="Center"/>
                                                <TextBlock Text="{x:Bind Message}" Foreground="{x:Bind MessageColor}" FontWeight="SemiBold" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="{x:Bind Details}" FontSize="12" Foreground="#888888" TextWrapping="Wrap" Margin="0,4,0,0" Visibility="{x:Bind DetailsVisibility}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Flyout>
                </Button.Flyout>
            </Button>
        </Grid>

        <NavigationView x:Name="MainNav" Grid.Row="1" 
                        IsBackButtonVisible="Collapsed" 
                        IsSettingsVisible="False"
                        PaneDisplayMode="Left"
                        SelectionChanged="MainNav_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Tag="FileConvert" Content="文件转换" Icon="Document" />
                <NavigationViewItem Tag="LrcMatch" Content="歌词匹配" Icon="Audio" />
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Tag="Settings" Content="设置" Icon="Setting" />
                <NavigationViewItem Tag="About" Content="关于" Icon="ContactInfo" />
            </NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame" Padding="0,20,20,20"/>
        </NavigationView>

        <StackPanel x:Name="ToastContainer" Grid.Row="1" 
             HorizontalAlignment="Right" VerticalAlignment="Top" 
            Margin="0,10,20,20" Spacing="10" 
            Width="300">
            <StackPanel.ChildrenTransitions>
                <TransitionCollection>
                    <AddDeleteThemeTransition/>
                    <RepositionThemeTransition IsStaggeringEnabled="False"/>
                </TransitionCollection>
            </StackPanel.ChildrenTransitions>
        </StackPanel>
    </Grid>
</Window>